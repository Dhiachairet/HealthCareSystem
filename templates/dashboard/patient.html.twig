{% extends 'base.html.twig' %}

{% block title %}MedicalApp - Patient Dashboard{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        :root {
            --primary: #2c7be5;
            --primary-light: #e3ebf8;
            --primary-dark: #1a68d1;
            --secondary: #6e84a3;
            --success: #00d97e;
            --success-light: #e6f9f0;
            --warning: #f6c343;
            --warning-light: #fef8e6;
            --danger: #e63757;
            --danger-light: #fce9ec;
            --info: #39afd1;
            --info-light: #eaf5f9;
            --light: #f9fbfd;
            --dark: #12263f;
            --gray-100: #f8f9fa;
            --gray-200: #e9ecef;
            --gray-300: #dee2e6;
            --gray-400: #ced4da;
            --gray-500: #adb5bd;
            --gray-600: #6c757d;
            --gray-700: #495057;
            --gray-800: #343a40;
            --gray-900: #212529;
            --sidebar-bg: #ffffff;
            --card-bg: #ffffff;
            --body-bg: #f5f7fb;
            --gradient-primary: linear-gradient(135deg, #2c7be5 0%, #1a68d1 100%);
            --gradient-success: linear-gradient(135deg, #00d97e 0%, #00b86c 100%);
            --gradient-warning: linear-gradient(135deg, #f6c343 0%, #f4b223 100%);
            --gradient-danger: linear-gradient(135deg, #e63757 0%, #d92545 100%);
            --shadow-sm: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
            --shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15);
            --shadow-lg: 0 1rem 3rem rgba(0, 0, 0, 0.175);
            --border-radius: 0.75rem;
            --border-radius-sm: 0.5rem;
            --transition: all 0.3s ease;
        }

        body {
            background-color: var(--body-bg);
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        }

        /* Main Dashboard Layout */
        .dashboard-wrapper {
            display: flex;
            min-height: 100vh;
        }

        /* Sidebar Navigation */
        .sidebar {
            width: 280px;
            background: var(--sidebar-bg);
            border-right: 1px solid var(--gray-200);
            position: fixed;
            height: 100vh;
            left: 0;
            top: 0;
            z-index: 1000;
            display: flex;
            flex-direction: column;
            box-shadow: var(--shadow);
            transition: var(--transition);
        }

        .sidebar-header {
            padding: 1.5rem;
            border-bottom: 1px solid var(--gray-200);
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .patient-avatar-large {
            width: 50px;
            height: 50px;
            background: var(--gradient-primary);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 1.25rem;
            font-weight: 600;
        }

        .patient-info h6 {
            margin-bottom: 0.25rem;
            font-weight: 600;
        }

        .patient-info small {
            color: var(--gray-600);
            font-size: 0.85rem;
        }

        .sidebar-nav {
            flex: 1;
            padding: 1.5rem;
            overflow-y: auto;
        }

        .nav-section {
            margin-bottom: 2rem;
        }

        .nav-section-title {
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
            color: var(--gray-600);
            letter-spacing: 0.5px;
            margin-bottom: 1rem;
        }

        .nav-item {
            display: flex;
            align-items: center;
            padding: 0.75rem 1rem;
            border-radius: var(--border-radius-sm);
            color: var(--gray-700);
            text-decoration: none;
            margin-bottom: 0.5rem;
            transition: var(--transition);
            font-weight: 500;
        }

        .nav-item:hover {
            background: var(--primary-light);
            color: var(--primary);
            transform: translateX(5px);
        }

        .nav-item.active {
            background: var(--gradient-primary);
            color: white;
            box-shadow: 0 4px 12px rgba(44, 123, 229, 0.3);
        }

        .nav-icon {
            width: 40px;
            height: 40px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-right: 1rem;
            background: var(--gray-100);
            color: var(--gray-600);
            transition: var(--transition);
        }

        .nav-item:hover .nav-icon {
            background: white;
        }

        .nav-item.active .nav-icon {
            background: rgba(255, 255, 255, 0.2);
            color: white;
        }

        .sidebar-footer {
            padding: 1.5rem;
            border-top: 1px solid var(--gray-200);
        }

        .logout-btn {
            display: flex;
            align-items: center;
            padding: 0.75rem 1rem;
            border-radius: var(--border-radius-sm);
            color: var(--danger);
            text-decoration: none;
            font-weight: 500;
            transition: var(--transition);
        }

        .logout-btn:hover {
            background: var(--danger-light);
        }

        /* Main Content Area */
        .main-content {
            flex: 1;
            margin-left: 280px;
            padding: 2rem;
            max-width: calc(100% - 280px);
        }

        /* Top Header */
        .top-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 2rem;
            padding-bottom: 1.5rem;
            border-bottom: 1px solid var(--gray-200);
        }

        .header-left h1 {
            font-size: 1.75rem;
            font-weight: 700;
            color: var(--dark);
            margin-bottom: 0.5rem;
        }

        .header-left p {
            color: var(--gray-600);
            margin: 0;
        }

        .header-right {
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .date-badge {
            background: var(--primary-light);
            color: var(--primary);
            padding: 0.5rem 1rem;
            border-radius: 50px;
            font-weight: 500;
            font-size: 0.9rem;
        }

        .notification-btn {
            width: 40px;
            height: 40px;
            border-radius: 10px;
            background: var(--gray-100);
            border: none;
            color: var(--gray-600);
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            transition: var(--transition);
        }

        .notification-btn:hover {
            background: var(--gray-200);
            color: var(--gray-700);
        }

        .notification-badge {
            position: absolute;
            top: -5px;
            right: -5px;
            background: var(--danger);
            color: white;
            font-size: 0.7rem;
            width: 20px;
            height: 20px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 600;
        }

        /* Stats Cards - Modern Design */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
            gap: 1.5rem;
            margin-bottom: 2rem;
        }

        .stat-card {
            background: var(--card-bg);
            border-radius: var(--border-radius);
            padding: 1.5rem;
            box-shadow: var(--shadow);
            border: 1px solid var(--gray-200);
            transition: var(--transition);
            position: relative;
            overflow: hidden;
        }

        .stat-card:hover {
            transform: translateY(-5px);
            box-shadow: var(--shadow-lg);
        }

        .stat-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 4px;
            height: 100%;
        }

        .stat-card.confirmed::before { background: var(--success); }
        .stat-card.pending::before { background: var(--warning); }
        .stat-card.total::before { background: var(--primary); }
        .stat-card.cancelled::before { background: var(--danger); }

        .stat-content {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
        }

        .stat-icon {
            width: 48px;
            height: 48px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            margin-bottom: 1rem;
        }

        .stat-card.confirmed .stat-icon {
            background: var(--success-light);
            color: var(--success);
        }

        .stat-card.pending .stat-icon {
            background: var(--warning-light);
            color: var(--warning);
        }

        .stat-card.total .stat-icon {
            background: var(--primary-light);
            color: var(--primary);
        }

        .stat-card.cancelled .stat-icon {
            background: var(--danger-light);
            color: var(--danger);
        }

        .stat-numbers h3 {
            font-size: 2rem;
            font-weight: 700;
            margin-bottom: 0.25rem;
            color: var(--dark);
        }

        .stat-numbers p {
            color: var(--gray-600);
            font-size: 0.9rem;
            margin: 0;
        }

        .stat-trend {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            font-size: 0.85rem;
            font-weight: 500;
        }

        .stat-trend.positive { color: var(--success); }
        .stat-trend.negative { color: var(--danger); }

        /* Appointments Section */
        .dashboard-section {
            background: var(--card-bg);
            border-radius: var(--border-radius);
            padding: 1.5rem;
            margin-bottom: 1.5rem;
            box-shadow: var(--shadow);
            border: 1px solid var(--gray-200);
        }

        .section-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1.5rem;
        }

        .section-header h3 {
            font-size: 1.25rem;
            font-weight: 600;
            color: var(--dark);
            margin: 0;
        }

        .section-actions {
            display: flex;
            gap: 0.5rem;
        }

        .btn-primary-action {
            padding: 0.5rem 1rem;
            background: var(--gradient-primary);
            color: white;
            border: none;
            border-radius: var(--border-radius-sm);
            font-size: 0.85rem;
            font-weight: 500;
            transition: var(--transition);
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
        }

        .btn-primary-action:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(44, 123, 229, 0.3);
            color: white;
        }

        /* Appointment Cards */
        .appointment-list {
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }

        .appointment-item {
            display: flex;
            align-items: center;
            padding: 1rem;
            background: var(--gray-100);
            border-radius: var(--border-radius-sm);
            transition: var(--transition);
            border-left: 4px solid transparent;
        }

        .appointment-item:hover {
            background: var(--gray-200);
            transform: translateX(5px);
        }

        .appointment-item.pending { border-left-color: var(--warning); }
        .appointment-item.confirmed { border-left-color: var(--success); }
        .appointment-item.cancelled { border-left-color: var(--danger); }

        .appointment-time {
            min-width: 100px;
            text-align: center;
            padding: 0.5rem;
            background: white;
            border-radius: 8px;
            margin-right: 1rem;
        }

        .appointment-time .time {
            font-size: 1.1rem;
            font-weight: 600;
            color: var(--dark);
            display: block;
        }

        .appointment-time .date {
            font-size: 0.85rem;
            color: var(--gray-600);
        }

        .doctor-info {
            flex: 1;
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .doctor-avatar-small {
            width: 40px;
            height: 40px;
            border-radius: 10px;
            background: var(--gradient-primary);
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: 600;
            font-size: 1rem;
        }

        .doctor-details h6 {
            font-weight: 600;
            margin-bottom: 0.25rem;
            color: var(--dark);
        }

        .doctor-details p {
            color: var(--gray-600);
            font-size: 0.85rem;
            margin: 0;
        }

        .appointment-status {
            padding: 0.25rem 0.75rem;
            border-radius: 50px;
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .status-pending {
            background: var(--warning-light);
            color: var(--warning);
        }

        .status-confirmed {
            background: var(--success-light);
            color: var(--success);
        }

        .status-cancelled {
            background: var(--danger-light);
            color: var(--danger);
        }

        .appointment-actions {
            display: flex;
            gap: 0.5rem;
        }

        .btn-action {
            padding: 0.5rem 0.75rem;
            border-radius: 8px;
            border: none;
            font-size: 0.85rem;
            font-weight: 500;
            transition: var(--transition);
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .btn-cancel {
            background: var(--danger-light);
            color: var(--danger);
        }

        .btn-cancel:hover {
            background: var(--danger);
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(230, 55, 87, 0.3);
        }

        .btn-disabled {
            background: var(--gray-300);
            color: var(--gray-600);
            padding: 0.5rem 0.75rem;
            border-radius: 8px;
            border: none;
            font-size: 0.85rem;
            font-weight: 500;
            cursor: not-allowed;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            opacity: 0.7;
        }

        /* Upcoming Section */
        .upcoming-appointments {
            background: var(--card-bg);
            border-radius: var(--border-radius);
            padding: 1.5rem;
            box-shadow: var(--shadow);
            border: 1px solid var(--gray-200);
        }

        .section-title {
            font-size: 1.1rem;
            font-weight: 600;
            color: var(--dark);
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .upcoming-list {
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
        }

        .upcoming-item {
            display: flex;
            align-items: center;
            padding: 0.75rem;
            background: var(--gray-100);
            border-radius: 8px;
            transition: var(--transition);
        }

        .upcoming-item:hover {
            background: var(--gray-200);
        }

        .upcoming-time {
            min-width: 70px;
            text-align: center;
            padding: 0.5rem;
            background: white;
            border-radius: 6px;
            margin-right: 0.75rem;
        }

        .upcoming-time .time {
            font-size: 0.9rem;
            font-weight: 600;
            color: var(--dark);
            display: block;
        }

        .upcoming-time .date {
            font-size: 0.75rem;
            color: var(--gray-600);
        }

        .upcoming-doctor {
            flex: 1;
        }

        .upcoming-doctor h6 {
            font-size: 0.9rem;
            font-weight: 600;
            margin-bottom: 0.125rem;
            color: var(--dark);
        }

        .upcoming-doctor p {
            font-size: 0.8rem;
            color: var(--gray-600);
            margin: 0;
        }

        /* Empty State */
        .empty-state {
            text-align: center;
            padding: 3rem 1rem;
            color: var(--gray-600);
        }

        .empty-state i {
            font-size: 3rem;
            margin-bottom: 1rem;
            color: var(--gray-400);
        }

        /* Toast notifications */
        .toast-notification {
            position: fixed;
            top: 20px;
            right: 20px;
            padding: 1rem 1.5rem;
            border-radius: var(--border-radius-sm);
            background: white;
            box-shadow: var(--shadow-lg);
            z-index: 9999;
            display: flex;
            align-items: center;
            animation: slideIn 0.3s ease;
            border-left: 4px solid;
        }

        .toast-success {
            border-left-color: var(--success);
            color: var(--success);
        }

        .toast-warning {
            border-left-color: var(--warning);
            color: var(--warning);
        }

        .toast-danger {
            border-left-color: var(--danger);
            color: var(--danger);
        }

        @keyframes slideIn {
            from {
                transform: translateX(100%);
                opacity: 0;
            }
            to {
                transform: translateX(0);
                opacity: 1;
            }
        }

        /* Flash Messages */
        .alert {
            border-radius: var(--border-radius-sm);
            border: none;
            box-shadow: var(--shadow-sm);
            margin-bottom: 1.5rem;
        }

        /* Responsive Design */
        @media (max-width: 1200px) {
            .sidebar {
                width: 250px;
            }
            .main-content {
                margin-left: 250px;
                max-width: calc(100% - 250px);
            }
        }

        @media (max-width: 992px) {
            .dashboard-wrapper {
                flex-direction: column;
            }
            .sidebar {
                width: 100%;
                height: auto;
                position: static;
                margin-bottom: 1rem;
            }
            .main-content {
                margin-left: 0;
                max-width: 100%;
                padding: 1rem;
            }
            .stats-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @media (max-width: 768px) {
            .stats-grid {
                grid-template-columns: 1fr;
            }
            .top-header {
                flex-direction: column;
                align-items: flex-start;
                gap: 1rem;
            }
            .header-right {
                width: 100%;
                justify-content: space-between;
            }
            .appointment-item {
                flex-direction: column;
                align-items: flex-start;
                gap: 1rem;
            }
            .appointment-time {
                width: 100%;
                text-align: left;
            }
            .appointment-actions {
                width: 100%;
                justify-content: flex-end;
            }
        }
    </style>
    <!-- Add Inter Font -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <!-- Add Font Awesome for icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
{% endblock %}

{% block body %}
    <div class="dashboard-wrapper">
        <!-- Sidebar Navigation -->
        <aside class="sidebar">
            <div class="sidebar-header">
                <div class="patient-avatar-large">
                    {{ app.user.firstName|first|upper }}{{ app.user.lastName|first|upper }}
                </div>
                <div class="patient-info">
                    <h6>{{ app.user.firstName }} {{ app.user.lastName }}</h6>
                    <small>Patient</small>
                </div>
            </div>

            <nav class="sidebar-nav">
                <div class="nav-section">
                    <div class="nav-section-title">Main</div>
                    <a href="{{ path('app_dashboard') }}" class="nav-item active">
                        <div class="nav-icon">
                            <i class="fas fa-home"></i>
                        </div>
                        Dashboard
                    </a>
                    <a href="{{ path('patient_appointments') }}" class="nav-item">
                        <div class="nav-icon">
                            <i class="fas fa-calendar-alt"></i>
                        </div>
                        Appointments
                    </a>
                    <a href="{{ path('patient_prescriptions') }}" class="nav-item">
                        <div class="nav-icon">
                            <i class="fas fa-file-prescription"></i>
                        </div>
                        Prescriptions
                    </a>
                </div>

                <div class="nav-section">
                    <div class="nav-section-title">Health</div>
                    <a href="{{ path('patient_doctors') }}" class="nav-item">
                        <div class="nav-icon">
                            <i class="fas fa-search"></i>
                        </div>
                        Find Doctors
                    </a>
                </div>
            </nav>

            <div class="sidebar-footer">
                <a href="{{ path('app_logout') }}" class="logout-btn">
                    <i class="fas fa-sign-out-alt me-2"></i> Logout
                </a>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="main-content">
            <!-- Top Header -->
            <div class="top-header">
                <div class="header-left">
                    <h1>Welcome, {{ app.user.firstName }}</h1>
                    <p>Manage your appointments and medical care</p>
                </div>
                <div class="header-right">
                    <div class="date-badge">
                        <i class="fas fa-calendar-day me-2"></i>{{ "now"|date("l, F j, Y") }}
                    </div>

                </div>
            </div>

            <!-- Flash Messages -->
            {% for message in app.flashes('success') %}
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="fas fa-check-circle me-2"></i>{{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endfor %}

            {% for message in app.flashes('warning') %}
                <div class="alert alert-warning alert-dismissible fade show" role="alert">
                    <i class="fas fa-exclamation-triangle me-2"></i>{{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endfor %}

            <!-- Stats Cards -->
            <!-- Stats Cards - DYNAMIC VERSION -->
            <div class="stats-grid">
                <div class="stat-card confirmed">
                    <div class="stat-content">
                        <div>
                            <div class="stat-icon">
                                <i class="fas fa-calendar-check"></i>
                            </div>
                            <div class="stat-numbers">
                                <h3>{{ appointments|filter(a => a.status == 'Confirmed' and a.startDateTime > "now")|length }}</h3>
                                <p>Upcoming Confirmed</p>
                            </div>
                        </div>

                    </div>
                </div>

                <div class="stat-card pending">
                    <div class="stat-content">
                        <div>
                            <div class="stat-icon">
                                <i class="fas fa-clock"></i>
                            </div>
                            <div class="stat-numbers">
                                <h3>{{ appointments|filter(a => a.status == 'Pending' and a.startDateTime > "now")|length }}</h3>
                                <p>Upcoming Pending</p>
                            </div>
                        </div>

                    </div>
                </div>

                <div class="stat-card total">
                    <div class="stat-content">
                        <div>
                            <div class="stat-icon">
                                <i class="fas fa-stethoscope"></i>
                            </div>
                            <div class="stat-numbers">
                                <h3>{{ appointments|filter(a => a.startDateTime > "now")|length }}</h3>
                                <p>Upcoming Total</p>
                            </div>
                        </div>

                    </div>
                </div>

                <div class="stat-card cancelled">
                    <div class="stat-content">
                        <div>
                            <div class="stat-icon">
                                <i class="fas fa-calendar-alt"></i>
                            </div>
                            <div class="stat-numbers">
                                <h3>{{ appointments|filter(a => a.status == 'Cancelled')|length }}</h3>
                                <p>Cancelled Total</p>
                            </div>
                        </div>


                    </div>
                </div>
            </div>
            <!-- Two Column Layout -->
            <div class="row">
                <!-- Today's Appointments Column -->
                <div class="col-lg-8">
                    <div class="dashboard-section">
                        <div class="section-header">
                            <h3><i class="fas fa-calendar-day me-2 text-primary"></i>Today's Appointments</h3>
                            <div class="section-actions">
                                <a href="{{ path('patient_doctors') }}" class="btn-primary-action">
                                    <i class="fas fa-search me-1"></i>Find Doctors
                                </a>
                            </div>
                        </div>

                        {% set todayAppointments = appointments|filter(a => a.startDateTime|date('Y-m-d') == "now"|date('Y-m-d') and a.startDateTime > "now") %}

                        {% if todayAppointments|length > 0 %}
                            <div class="appointment-list">
                                {% for appointment in todayAppointments %}
                                    <div class="appointment-item {{ appointment.status|lower }}">
                                        <div class="appointment-time">
                                            <span class="time">{{ appointment.startDateTime|date('h:i A') }}</span>
                                            <span class="date">Today</span>
                                        </div>
                                        <div class="doctor-info">
                                            <div class="doctor-avatar-small">
                                                {{ appointment.doctor.client.firstName|first|upper }}{{ appointment.doctor.client.lastName|first|upper }}
                                            </div>
                                            <div class="doctor-details">
                                                <h6>Dr. {{ appointment.doctor.client.firstName }} {{ appointment.doctor.client.lastName }}</h6>
                                                <p>
                                                    <i class="fas fa-stethoscope me-1"></i>{{ appointment.doctor.specialty ?? 'General Medicine' }}
                                                    <br>
                                                    <i class="fas fa-phone me-1"></i>{{ appointment.doctor.phone ?? 'No phone' }}
                                                </p>
                                            </div>
                                        </div>
                                        <span class="appointment-status status-{{ appointment.status|lower }}">
                                            {{ appointment.status }}
                                        </span>
                                        <div class="appointment-actions">
                                            {% if appointment.status == 'Pending' %}
                                                <button class="btn-action btn-cancel" onclick="cancelAppointment({{ appointment.id }})" title="Cancel Appointment">
                                                    <i class="fas fa-times"></i> Cancel
                                                </button>
                                            {% elseif appointment.status == 'Confirmed' %}
                                                {# Only show disabled message or nothing for confirmed appointments #}
                                                {# Option 1: Show nothing #}
                                                {# Option 2: Show disabled button with message #}
                                                <span class="btn-action btn-disabled" title="Cannot cancel confirmed appointments">
                                                    <i class="fas fa-ban me-1"></i> Cannot Cancel
                                                </span>
                                            {% endif %}
                                        </div>
                                    </div>
                                {% endfor %}
                            </div>
                        {% else %}
                            <div class="empty-state">
                                <i class="fas fa-calendar-check"></i>
                                <h5>No appointments today</h5>
                                <p>You don't have any appointments scheduled for today.</p>
                            </div>
                        {% endif %}
                    </div>

                    <!-- Upcoming Appointments -->
                </div>

                <!-- Right Column -->
                <div class="col-lg-4">
                    <!-- Quick Stats -->

                    <!-- Profile Summary -->
                    <div class="upcoming-appointments">
                        <h4 class="section-title">
                            <i class="fas fa-user me-2 text-primary"></i>Profile Summary
                        </h4>

                        <div class="text-center mb-3">
                            <div class="doctor-avatar-small" style="width: 60px; height: 60px; font-size: 1.25rem; margin: 0 auto 1rem;">
                                {{ app.user.firstName|first|upper }}{{ app.user.lastName|first|upper }}
                            </div>
                            <h6>{{ app.user.firstName }} {{ app.user.lastName }}</h6>
                            <p class="text-muted mb-0">Patient</p>
                        </div>

                        <div class="upcoming-list">
                            <div class="upcoming-item" style="background: transparent; justify-content: center; border: 1px solid var(--gray-200);">
                                <div class="text-center">
                                    <div class="stat-number" style="font-size: 1.75rem; margin-bottom: 0.25rem;">
                                        {{ appointments|length }}
                                    </div>
                                    <div class="stat-label">Total Appointments</div>
                                </div>
                            </div>
                        </div>

                        <div class="mt-3">
                            <a href="{{ path('patient_appointments') }}" class="btn-primary-action w-100">
                                <i class="fas fa-calendar-alt me-1"></i>View All Appointments
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        function cancelAppointment(appointmentId) {
            if (confirm('Are you sure you want to cancel this appointment? This action cannot be undone.')) {
                fetch('/patient/appointment/' + appointmentId + '/cancel', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            showToast('Appointment cancelled successfully!', 'warning');
                            setTimeout(() => {
                                location.reload();
                            }, 1500);
                        } else {
                            showToast('Error: ' + data.message, 'danger');
                        }
                    })
                    .catch(error => {
                        console.error('Error:', error);
                        showToast('Error cancelling appointment', 'danger');
                    });
            }
        }

        // Toast notification function
        function showToast(message, type = 'success') {
            // Remove existing toasts
            document.querySelectorAll('.toast-notification').forEach(toast => toast.remove());

            // Create toast element
            const toast = document.createElement('div');
            toast.className = `toast-notification toast-${type}`;
            toast.innerHTML = `
                <i class="fas fa-${type === 'success' ? 'check-circle' : type === 'warning' ? 'exclamation-triangle' : 'exclamation-circle'} me-2"></i>
                ${message}
            `;

            // Add to page
            document.body.appendChild(toast);

            // Remove after 3 seconds
            setTimeout(() => {
                if (toast.parentNode) {
                    toast.remove();
                }
            }, 3000);
        }

        // Add hover effects
        document.addEventListener('DOMContentLoaded', function() {
            // Add animation to stats cards on load
            const statCards = document.querySelectorAll('.stat-card');
            statCards.forEach((card, index) => {
                setTimeout(() => {
                    card.style.opacity = '1';
                    card.style.transform = 'translateY(0)';
                }, index * 100);
            });

            // Initialize tooltips
            const tooltips = document.querySelectorAll('[title]');
            tooltips.forEach(tooltip => {
                new bootstrap.Tooltip(tooltip);
            });

            // Notification button click
            const notificationBtn = document.querySelector('.notification-btn');
            if (notificationBtn) {
                notificationBtn.addEventListener('click', function() {
                    // In a real app, this would show notifications
                    showToast('Notifications feature coming soon!', 'info');
                });
            }
        });
    </script>
{% endblock %}